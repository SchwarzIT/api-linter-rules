{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "title": "RFC-9457 Problem Details Meta-Schema",
  "description": "A meta-schema that validates if an OpenAPI Schema Object correctly defines an RFC-9457 Problem Details object with all recommended constraints.",
  "type": "object",
  "properties": {
    "type": { "const": "object" },
    "properties": {
      "type": "object",
      "properties": {
        "type": {
          "type": "object",
          "properties": {
            "type": { "const": "string" },
            "format": { "const": "uri" },
            "maxLength": { "const": 1024 }
          },
          "required": ["type", "format", "maxLength"],
          "description": "A URI reference that identifies the problem type.",
          "x-extensive-description": "According to RFC-9457, this member identifies the problem type. When dereferenced, it should provide human-readable documentation for the problem type (e.g., using HTML)."
        },
        "status": {
          "type": "object",
          "properties": {
            "type": { "const": "integer" },
            "format": { "const": "int32" },
            "minimum": { "const": 100 },
            "maximum": { "const": 599 }
          },
          "required": ["type", "format", "minimum", "maximum"],
          "description": "The HTTP status code generated by the origin server for this occurrence of the problem."
        },
        "title": {
          "type": "object",
          "properties": {
            "type": { "const": "string" },
            "maxLength": { "const": 1024 }
          },
          "required": ["type", "maxLength"],
          "description": "A short, human-readable summary of the problem type."
        },
        "detail": {
          "type": "object",
          "properties": {
            "type": { "const": "string" },
            "maxLength": { "const": 4096 }
          },
          "required": ["type", "maxLength"],
          "description": "A human-readable explanation specific to this occurrence of the problem."
        },
        "instance": {
          "type": "object",
          "properties": {
            "type": { "const": "string" },
            "format": { "const": "uri" },
            "maxLength": { "const": 1024 }
          },
          "required": ["type", "format", "maxLength"],
          "description": "A URI reference that identifies the specific occurrence of the problem."
        },
        "code": {
          "type": "object",
          "properties": {
            "type": { "const": "string" },
            "maxLength": { "const": 50 }
          },
          "required": ["type", "maxLength"],
          "description": "An API specific error code aiding the provider team understand the error."
        },
        "errors": {
          "type": "object",
          "properties": {
            "type": { "const": "array" },
            "maxItems": { "const": 1000 },
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "object" },
                "properties": {
                  "type": "object",
                  "properties": {
                    "detail": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "string" },
                        "maxLength": { "const": 4096 }
                      },
                      "required": ["type", "maxLength"]
                    },
                    "pointer": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "string" },
                        "maxLength": { "const": 1024 }
                      },
                      "required": ["type", "maxLength"]
                    },
                    "parameter": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "string" },
                        "maxLength": { "const": 1024 }
                      },
                      "required": ["type", "maxLength"]
                    },
                    "header": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "string" },
                        "maxLength": { "const": 1024 }
                      },
                      "required": ["type", "maxLength"]
                    },
                    "code": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "string" },
                        "maxLength": { "const": 50 }
                      },
                      "required": ["type", "maxLength"]
                    }
                  },
                  "required": ["detail"]
                },
                "required": {
                  "type": "array",
                  "contains": { "const": "detail" }
                }
              },
              "required": ["type", "properties", "required"]
            }
          },
          "required": ["type", "maxItems", "items"],
          "description": "An array of error details to accompany a problem details response."
        }
      },
      "required": ["detail"]
    },
    "required": {
      "type": "array",
      "contains": { "const": "detail" }
    }
  },
  "required": ["type", "properties", "required"]
}
